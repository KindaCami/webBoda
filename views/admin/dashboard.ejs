<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Admin · Panel de Control · Nuestra Boda</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --green: #00ff88; --blue: #0088ff; --pink: #ff00cc; --gold: #ffd700;
            --orange: #ffa500; --red: #ff4444;
            --surface: rgba(8,8,20,0.9); --border: rgba(255,255,255,0.07);
        }
        body { min-height: 100vh; background: #000; color: #fff; font-family: 'Inter', sans-serif;
            background-image: radial-gradient(ellipse at 10% 20%, rgba(255,0,204,0.03) 0%, transparent 50%),
                              radial-gradient(ellipse at 90% 80%, rgba(0,136,255,0.03) 0%, transparent 50%);
        }

        .admin-nav {
            position: sticky; top: 0; z-index: 100;
            background: rgba(0,0,0,0.95); backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            padding: 0 32px;
            display: flex; align-items: center; justify-content: space-between;
            height: 56px;
        }
        .nav-brand { font-family: 'Orbitron', monospace; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.25em; color: var(--pink); }
        .nav-links { display: flex; gap: 4px; }
        .nav-link { font-family: 'Orbitron', monospace; font-size: 0.55rem; letter-spacing: 0.15em; color: rgba(255,255,255,0.4); text-decoration: none; padding: 6px 12px; border-radius: 3px; transition: color 0.2s, background 0.2s; }
        .nav-link:hover { color: #fff; background: rgba(255,255,255,0.05); }
        .nav-link.active { color: var(--green); background: rgba(0,255,136,0.08); }
        .nav-right { display: flex; align-items: center; gap: 16px; }
        .nav-user { font-family: 'Orbitron', monospace; font-size: 0.55rem; color: rgba(255,255,255,0.3); }
        .btn-logout-nav { font-family: 'Orbitron', monospace; font-size: 0.55rem; letter-spacing: 0.15em; color: rgba(255,60,60,0.6); text-decoration: none; padding: 6px 10px; border: 1px solid rgba(255,60,60,0.2); border-radius: 3px; transition: color 0.2s, border-color 0.2s; }
        .btn-logout-nav:hover { color: var(--red); border-color: rgba(255,60,60,0.5); }

        .page { max-width: 1280px; margin: 0 auto; padding: 32px 24px; }

        .flash { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-radius: 3px; margin-bottom: 24px; font-size: 0.85rem; }
        .flash-success { background: rgba(0,255,136,0.07); border: 1px solid rgba(0,255,136,0.2); border-left: 3px solid var(--green); color: var(--green); }
        .flash-error   { background: rgba(255,60,60,0.07); border: 1px solid rgba(255,60,60,0.2); border-left: 3px solid var(--red); color: #ff7070; }

        .section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
        .section-title { font-family: 'Orbitron', monospace; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.4); }
        .section-divider { height: 1px; background: var(--border); margin: 36px 0; }

        /* STAT CARDS */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; margin-bottom: 32px; }
        .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; padding: 20px; position: relative; overflow: hidden; }
        .stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; }
        .stat-green::before { background: var(--green); }
        .stat-blue::before  { background: var(--blue); }
        .stat-pink::before  { background: var(--pink); }
        .stat-gold::before  { background: var(--gold); }
        .stat-orange::before { background: var(--orange); }
        .stat-red::before   { background: var(--red); }
        .stat-label { font-family: 'Orbitron', monospace; font-size: 0.52rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 10px; }
        .stat-value { font-family: 'Orbitron', monospace; font-size: 2rem; font-weight: 900; color: #fff; line-height: 1; }
        .stat-sub { font-size: 0.75rem; color: rgba(255,255,255,0.3); margin-top: 6px; }
        .beds-bar { margin-top: 8px; height: 4px; background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden; }
        .beds-fill { height: 100%; border-radius: 2px; transition: width 0.5s ease; }

        /* CHARTS */
        .charts-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 32px; }
        .chart-card { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; padding: 24px; }
        .chart-title { font-family: 'Orbitron', monospace; font-size: 0.58rem; letter-spacing: 0.2em; color: rgba(255,255,255,0.35); text-transform: uppercase; margin-bottom: 16px; }
        .chart-wrap { position: relative; height: 160px; }

        /* ECONOMÍA */
        .economia-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
        .eco-card { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; padding: 24px; }
        .eco-card-title { font-family: 'Orbitron', monospace; font-size: 0.58rem; letter-spacing: 0.2em; color: rgba(255,255,255,0.35); text-transform: uppercase; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
        .eco-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.82rem; }
        .eco-row:last-child { border-bottom: none; }
        .eco-label { color: rgba(255,255,255,0.5); }
        .eco-value { font-family: 'Orbitron', monospace; font-size: 0.8rem; font-weight: 700; color: #fff; }
        .eco-total { display: flex; justify-content: space-between; align-items: center; padding: 14px 0 0; margin-top: 8px; border-top: 1px solid rgba(255,255,255,0.1); }
        .eco-total-label { font-family: 'Orbitron', monospace; font-size: 0.6rem; letter-spacing: 0.15em; color: var(--green); }
        .eco-total-value { font-family: 'Orbitron', monospace; font-size: 1.4rem; font-weight: 900; color: var(--green); }
        .eco-note { font-size: 0.7rem; color: rgba(255,255,255,0.2); margin-top: 6px; font-style: italic; }
        .eco-warn { background: rgba(255,165,0,0.07); border: 1px solid rgba(255,165,0,0.2); border-left: 3px solid var(--orange); border-radius: 3px; padding: 12px 16px; font-size: 0.82rem; color: var(--orange); margin-bottom: 16px; }
        .eco-breakdown { background: rgba(255,255,255,0.02); border-radius: 3px; padding: 12px; margin-top: 12px; }
        .eco-breakdown-row { display: flex; justify-content: space-between; font-size: 0.75rem; padding: 3px 0; }
        .eco-breakdown-label { color: rgba(255,255,255,0.4); }
        .eco-breakdown-value { color: rgba(255,255,255,0.7); font-family: 'Orbitron', monospace; font-size: 0.7rem; }

        /* SOLO SABADO */
        .solo-sabado-card { background: var(--surface); border: 1px solid rgba(255,215,0,0.2); border-left: 3px solid var(--gold); border-radius: 4px; padding: 20px; margin-bottom: 16px; }
        .solo-sabado-title { font-family: 'Orbitron', monospace; font-size: 0.58rem; letter-spacing: 0.2em; color: var(--gold); text-transform: uppercase; margin-bottom: 12px; }

        /* TABLE */
        .table-controls { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
        .search-input { background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 3px; padding: 8px 14px; color: #fff; font-family: 'Inter', sans-serif; font-size: 0.85rem; outline: none; width: 240px; transition: border-color 0.2s; }
        .search-input:focus { border-color: rgba(0,255,136,0.4); }
        .search-input::placeholder { color: rgba(255,255,255,0.2); }
        .btn { font-family: 'Orbitron', monospace; font-size: 0.58rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; padding: 8px 16px; border-radius: 3px; cursor: pointer; border: none; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: background 0.2s, box-shadow 0.2s; }
        .btn-green  { background: var(--green); color: #000; box-shadow: 0 0 16px rgba(0,255,136,0.2); }
        .btn-green:hover { background: #33ffaa; }
        .btn-pink   { background: rgba(255,0,204,0.15); color: var(--pink); border: 1px solid rgba(255,0,204,0.3); }
        .btn-pink:hover { background: rgba(255,0,204,0.25); }
        .btn-red    { background: rgba(255,60,60,0.12); color: var(--red); border: 1px solid rgba(255,60,60,0.25); font-size: 0.5rem; padding: 5px 10px; }
        .btn-red:hover { background: rgba(255,60,60,0.22); }
        .btn-edit   { background: rgba(0,136,255,0.12); color: var(--blue); border: 1px solid rgba(0,136,255,0.25); font-size: 0.5rem; padding: 5px 10px; }
        .btn-edit:hover { background: rgba(0,136,255,0.22); }

        .table-wrap { overflow-x: auto; margin-top: 16px; }
        table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
        thead th { font-family: 'Orbitron', monospace; font-size: 0.52rem; letter-spacing: 0.15em; color: rgba(255,255,255,0.3); text-transform: uppercase; padding: 10px 12px; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }
        tbody tr { border-bottom: 1px solid rgba(255,255,255,0.03); transition: background 0.15s; }
        tbody tr:hover { background: rgba(255,255,255,0.02); }
        tbody td { padding: 10px 12px; color: rgba(255,255,255,0.75); vertical-align: middle; }
        .td-name { font-weight: 600; color: #fff; }
        .td-group { font-size: 0.75rem; color: rgba(255,255,255,0.35); }

        .badge { display: inline-block; font-family: 'Orbitron', monospace; font-size: 0.48rem; letter-spacing: 0.1em; padding: 2px 7px; border-radius: 2px; font-weight: 700; }
        .badge-si      { background: rgba(0,255,136,0.12); color: var(--green); }
        .badge-no      { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.2); }
        .badge-vip     { background: rgba(255,215,0,0.12); color: var(--gold); border: 1px solid rgba(255,215,0,0.2); }
        .badge-conf    { background: rgba(0,255,136,0.1); color: var(--green); border: 1px solid rgba(0,255,136,0.2); }
        .badge-wait    { background: rgba(255,165,0,0.1); color: var(--orange); border: 1px solid rgba(255,165,0,0.2); }
        .badge-none    { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.07); }
        .badge-menu    { background: rgba(0,136,255,0.1); color: var(--blue); }
        .badge-adulto  { background: rgba(0,255,136,0.08); color: var(--green); border: 1px solid rgba(0,255,136,0.15); }
        .badge-adol    { background: rgba(255,165,0,0.08); color: var(--orange); border: 1px solid rgba(255,165,0,0.15); }
        .badge-nino    { background: rgba(255,0,204,0.08); color: var(--pink); border: 1px solid rgba(255,0,204,0.15); }

        .allergy-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
        .allergy-card { background: var(--surface); border: 1px solid var(--border); border-left: 3px solid var(--orange); border-radius: 4px; padding: 16px; }
        .allergy-name { font-weight: 600; color: #fff; margin-bottom: 4px; }
        .allergy-group { font-size: 0.75rem; color: rgba(255,255,255,0.3); margin-bottom: 10px; }
        .allergy-detail { font-size: 0.8rem; color: rgba(255,255,255,0.6); line-height: 1.5; }
        .allergy-tag { display: inline-block; font-size: 0.7rem; padding: 2px 8px; border-radius: 2px; margin-bottom: 4px; }

        .waiting-table td, .waiting-table th { padding: 8px 12px; }

        .settings-card { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; padding: 24px; max-width: 400px; }
        .settings-row { display: flex; gap: 10px; align-items: flex-end; margin-top: 12px; }
        .settings-row input { background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 3px; padding: 10px 14px; color: #fff; font-family: 'Orbitron', monospace; font-size: 1rem; font-weight: 700; width: 100px; outline: none; text-align: center; }

        .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 200; display: none; align-items: center; justify-content: center; padding: 24px; }
        .modal-overlay.open { display: flex; }
        .modal { background: #0d0d1a; border: 1px solid var(--border); border-radius: 4px; width: 100%; max-width: 480px; overflow: hidden; }
        .modal-accent { height: 3px; background: linear-gradient(90deg, var(--blue), var(--green)); }
        .modal-body { padding: 28px; }
        .modal-title { font-family: 'Orbitron', monospace; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.2em; color: var(--blue); margin-bottom: 20px; }
        .modal-field { margin-bottom: 14px; }
        .modal-field label { display: block; font-family: 'Orbitron', monospace; font-size: 0.52rem; letter-spacing: 0.18em; color: rgba(255,255,255,0.3); text-transform: uppercase; margin-bottom: 6px; }
        .modal-field input, .modal-field select, .modal-field textarea { width: 100%; background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 3px; padding: 10px 12px; color: #fff; font-family: 'Inter', sans-serif; font-size: 0.85rem; outline: none; }
        .modal-field select option { background: #0d0d1a; }
        .modal-field textarea { resize: vertical; min-height: 64px; }
        .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }
        .btn-cancel { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.4); border: 1px solid var(--border); }

        @media (max-width: 900px) {
            .charts-grid, .economia-grid { grid-template-columns: 1fr 1fr; }
            .stats-grid { grid-template-columns: repeat(3, 1fr); }
        }
        @media (max-width: 600px) {
            .charts-grid, .economia-grid { grid-template-columns: 1fr; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .admin-nav { padding: 0 16px; }
            .nav-links { display: none; }
        }
    </style>
</head>
<body>

<nav class="admin-nav">
    <span class="nav-brand">✦ ADMIN · BODA</span>
    <div class="nav-links">
        <a href="#stats"    class="nav-link active">Stats</a>
        <a href="#economia" class="nav-link">Economía</a>
        <a href="#guests"   class="nav-link">Invitados</a>
        <a href="#allergy"  class="nav-link">Alergias</a>
        <a href="#waiting"  class="nav-link">Espera</a>
        <a href="#settings" class="nav-link">Config</a>
    </div>
    <div class="nav-right">
        <span class="nav-user">👤 <%= typeof adminUser !== 'undefined' ? adminUser : 'admin' %></span>
        <a href="/admin/logout" class="btn-logout-nav">⏻ Salir</a>
    </div>
</nav>

<div class="page">

    <% if (success) { %>
    <div class="flash flash-success">✓ <%= success %></div>
    <% } %>
    <% if (error) { %>
    <div class="flash flash-error">⚠ <%= error %></div>
    <% } %>

    <!-- ══ STATS ══ -->
    <div id="stats">
        <div class="section-head">
            <span class="section-title">✦ Estadísticas generales</span>
        </div>

        <div class="stats-grid">
            <div class="stat-card stat-green">
                <div class="stat-label">Total invitados</div>
                <div class="stat-value"><%= stats.total_guests || 0 %></div>
                <div class="stat-sub"><%= stats.confirmed_guests || 0 %> han confirmado</div>
            </div>
            <div class="stat-card stat-green">
                <div class="stat-label">Adultos</div>
                <div class="stat-value"><%= stats.total_adultos || 0 %></div>
                <div class="stat-sub">166€ paquete principal</div>
            </div>
            <div class="stat-card stat-orange">
                <div class="stat-label">Adolescentes</div>
                <div class="stat-value" style="color:var(--orange)"><%= stats.total_adolescentes || 0 %></div>
                <div class="stat-sub">12–17 años · 150,5€</div>
            </div>
            <div class="stat-card stat-pink">
                <div class="stat-label">Niños</div>
                <div class="stat-value" style="color:var(--pink)"><%= stats.total_ninos || 0 %></div>
                <div class="stat-sub">0–11 años · 48,5€</div>
            </div>
            <div class="stat-card stat-gold">
                <div class="stat-label">Ceremonia 2026</div>
                <div class="stat-value"><%= stats.ceremony_2026 || 0 %></div>
                <div class="stat-sub">Plaza Mayor, Madrid</div>
            </div>
            <div class="stat-card stat-blue">
                <div class="stat-label">Viernes 2027</div>
                <div class="stat-value"><%= stats.friday_2027 || 0 %></div>
                <div class="stat-sub">Cena bienvenida</div>
            </div>
            <div class="stat-card stat-pink">
                <div class="stat-label">Sábado 2027</div>
                <div class="stat-value"><%= stats.saturday_2027 || 0 %></div>
                <div class="stat-sub">Gran fiesta</div>
            </div>
            <div class="stat-card stat-green">
                <div class="stat-label">Domingo 2027</div>
                <div class="stat-value"><%= stats.sunday_2027 || 0 %></div>
                <div class="stat-sub">Brunch despedida</div>
            </div>
            <div class="stat-card stat-blue">
                <div class="stat-label">Camas libres</div>
                <div class="stat-value" style="color: <%= stats.free_spots > 10 ? '#00ff88' : stats.free_spots > 0 ? '#ffa500' : '#ff4444' %>">
                    <%= stats.free_spots || 0 %>
                </div>
                <div class="stat-sub">de <%= stats.max_spots %> disponibles</div>
                <div class="beds-bar">
                    <div class="beds-fill" style="width: <%= Math.min(100, ((stats.confirmed_acc || 0) / stats.max_spots) * 100) %>%; background: <%= stats.free_spots > 10 ? '#00ff88' : stats.free_spots > 0 ? '#ffa500' : '#ff4444' %>"></div>
                </div>
            </div>
            <div class="stat-card stat-orange">
                <div class="stat-label">Lista espera</div>
                <div class="stat-value" style="color: var(--orange)"><%= stats.waiting_acc || 0 %></div>
                <div class="stat-sub">personas esperando</div>
            </div>
            <div class="stat-card stat-green">
                <div class="stat-label">Noches Viernes</div>
                <div class="stat-value"><%= stats.acc_friday || 0 %></div>
                <div class="stat-sub">21 → 22 Mayo</div>
            </div>
            <div class="stat-card stat-blue">
                <div class="stat-label">Noches Sábado</div>
                <div class="stat-value"><%= stats.acc_saturday || 0 %></div>
                <div class="stat-sub">22 → 23 Mayo</div>
            </div>
        </div>
    </div>

    <!-- ══ GRÁFICAS ══ -->
    <div class="charts-grid">
        <div class="chart-card">
            <div class="chart-title">Asistencia por evento</div>
            <div class="chart-wrap"><canvas id="chartEventos"></canvas></div>
        </div>
        <div class="chart-card">
            <div class="chart-title">Tipo de menú</div>
            <div class="chart-wrap"><canvas id="chartMenus"></canvas></div>
        </div>
        <div class="chart-card">
            <div class="chart-title">Distribución por edad</div>
            <div class="chart-wrap"><canvas id="chartEdades"></canvas></div>
        </div>
    </div>

    <div class="section-divider"></div>

    <!-- ══ ECONOMÍA ══ -->
    <div id="economia">
        <div class="section-head">
            <span class="section-title">✦ Estimación económica · Tejera Negra 2027</span>
        </div>

        <%
        const IVA = 1.10;
        const fmt = (v) => v.toLocaleString('es-ES', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' €';
        const ni = (v) => parseInt(v) || 0;

        const adSab    = ni(stats.adultos_sabado);
        const adolSab  = ni(stats.adolescentes_sabado);
        const ninSab   = ni(stats.ninos_sabado);
        const totalSab = adSab + adolSab + ninSab;

        const soloSab = ni(stats.solo_sabado);

        const totalDuermen = ni(stats.total_duermen);
        const CAMAS_TEJERA = 100;
        const sinCama = Math.max(0, totalDuermen - CAMAS_TEJERA);

        // ── SERVICIOS PRINCIPALES ──
        // Mínimo 100 adultos+adolescentes facturados
        const adultosYAdolSab = adSab + adolSab;
        const adultosFacturados = Math.max(adultosYAdolSab, 100);

        // Precios por persona (sin IVA), del contrato
        // Adulto: cóctel 17 + banquete 118 + barra libre 31 = 166€
        // Adolescente: cóctel 17 + banquete 118 + barra libre 15.5 = 150.5€
        // Niño 6-12: paquete infantil 48.5€
        // Niño 0-5: gratis

        // Tejera factura adultos+adolescentes juntos al precio adulto (mín 100)
        // más niños al precio infantil
        const ninoPagante = ninSab; // todos los niños del sábado (asumimos 6-12, ajustar manualmente si hay 0-5)

        const costePrincipalSinIVA = (adultosFacturados * 166) + (ninoPagante * 48.5);
        const costePrincipalConIVA = costePrincipalSinIVA * IVA;

        // Desglose
        const costeAdultos  = adultosFacturados * 166;
        const costeNinos    = ninoPagante * 48.5;
        const diferencia    = adultosFacturados - adultosYAdolSab; // personas de relleno hasta mín 100
        %>

        <!-- ALERTA MÍNIMO 100 -->
        <% if (adultosYAdolSab < 100) { %>
        <div class="eco-warn">
            ⚠ Solo hay <strong><%= adultosYAdolSab %></strong> adultos+adolescentes confirmados para el sábado.
            Tejera Negra factura mínimo <strong>100</strong> — pagaréis <strong><%= diferencia %> personas extra</strong> aunque no vengan.
        </div>
        <% } %>

        <!-- ALERTA ALOJAMIENTO EXTERNO -->
        <% if (sinCama > 0) { %>
        <div class="eco-warn" style="border-left-color: var(--red); color: var(--red); background: rgba(255,60,60,0.07); border-color: rgba(255,60,60,0.2);">
            🛏 <strong><%= totalDuermen %></strong> personas quieren dormir pero Tejera Negra solo tiene <strong><%= CAMAS_TEJERA %></strong> camas incluidas.
            Hay <strong><%= sinCama %> personas sin cama</strong> — necesitas buscarles alojamiento externo.
        </div>
        <% } %>

        <!-- SOLO SÁBADO SIN DORMIR -->
        <div class="solo-sabado-card">
            <div class="solo-sabado-title">⚡ Solo sábado · sin alojamiento</div>
            <div style="display:flex; gap:32px; flex-wrap:wrap;">
                <div>
                    <div style="font-family:'Orbitron',monospace; font-size:2rem; font-weight:900; color:var(--gold)"><%= soloSab %></div>
                    <div style="font-size:0.75rem; color:rgba(255,255,255,0.4); margin-top:4px;">personas confirmadas el sábado<br>sin noche del viernes ni del sábado</div>
                </div>
                <div style="font-size:0.82rem; color:rgba(255,255,255,0.4); line-height:2; align-self:center; border-left:1px solid rgba(255,255,255,0.08); padding-left:24px;">
                    <div>Total sábado: <strong style="color:#fff"><%= totalSab %></strong></div>
                    <div>Duermen en Tejera: <strong style="color:#fff"><%= totalDuermen %></strong></div>
                    <div>Solo vienen el día: <strong style="color:var(--gold)"><%= soloSab %></strong></div>
                    <% if (sinCama > 0) { %><div>Sin cama asignada: <strong style="color:var(--red)"><%= sinCama %></strong></div><% } %>
                </div>
            </div>
        </div>

        <!-- SERVICIOS PRINCIPALES -->
        <div class="eco-card" style="border-color: rgba(0,255,136,0.15);">
            <div class="eco-card-title">🎉 Servicios principales · Sábado 22 Mayo 2027</div>

            <div class="eco-row">
                <span class="eco-label">Adultos+adolescentes facturados <% if(diferencia > 0) { %><span style="color:var(--orange)">(mín. 100 · +<%= diferencia %> vacíos)</span><% } %></span>
                <span class="eco-value"><%= adultosFacturados %> × 166€</span>
            </div>
            <div class="eco-row">
                <span class="eco-label">Niños menú infantil (6-12)</span>
                <span class="eco-value"><%= ninoPagante %> × 48,5€</span>
            </div>

            <div class="eco-breakdown">
                <div style="font-family:'Orbitron',monospace; font-size:0.5rem; letter-spacing:0.15em; color:rgba(255,255,255,0.2); margin-bottom:8px;">DESGLOSE PAQUETE ADULTO (166€)</div>
                <div class="eco-breakdown-row"><span class="eco-breakdown-label">Cóctel (17€/p)</span><span class="eco-breakdown-value"><%= fmt(adultosFacturados * 17) %></span></div>
                <div class="eco-breakdown-row"><span class="eco-breakdown-label">Banquete (118€/p)</span><span class="eco-breakdown-value"><%= fmt(adultosFacturados * 118) %></span></div>
                <div class="eco-breakdown-row"><span class="eco-breakdown-label">Barra libre 3h (31€/p)</span><span class="eco-breakdown-value"><%= fmt(adultosFacturados * 31) %></span></div>
                <div class="eco-breakdown-row"><span class="eco-breakdown-label">Niños infantil (48,5€/p)</span><span class="eco-breakdown-value"><%= fmt(costeNinos) %></span></div>
                <div class="eco-breakdown-row"><span class="eco-breakdown-label">Ceremonia civil estándar</span><span class="eco-breakdown-value">385,00 €</span></div>
            </div>

            <div class="eco-total">
                <span class="eco-total-label">Sin IVA</span>
                <span class="eco-total-value"><%= fmt(costePrincipalSinIVA + 385) %></span>
            </div>
            <div class="eco-total" style="padding-top:6px; margin-top:0; border-top:none;">
                <span style="font-family:'Orbitron',monospace; font-size:0.55rem; color:rgba(255,255,255,0.3)">Con IVA (10%)</span>
                <span style="font-family:'Orbitron',monospace; font-size:1.4rem; font-weight:900; color:var(--green)"><%= fmt((costePrincipalSinIVA + 385) * IVA) %></span>
            </div>
            <p class="eco-note" style="margin-top:8px;">
                Incluye: cóctel + banquete + barra libre 3h + montaje ceremonia civil estándar + 1 noche alojamiento hasta 100 pax<br>
                No incluye: DJ (470€), maestro de ceremonias, derechos SGAE/AGEDI, toallas (1,5€/p), servicios extras
            </p>
        </div>
    </div>

    <div class="section-divider"></div>

    <!-- ══ INVITADOS ══ -->
    <div id="guests">
        <div class="section-head">
            <span class="section-title">✦ Todos los invitados</span>
            <div class="table-controls">
                <input type="text" class="search-input" id="searchInput" placeholder="🔍 Buscar invitado o grupo...">
                <a href="/admin/export/csv" class="btn btn-green">⬇ Exportar CSV</a>
            </div>
        </div>

        <div class="table-wrap">
            <table id="guestTable">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Grupo</th>
                        <th>Edad</th>
                        <th>Email</th>
                        <th>Cer'26</th>
                        <th>Vie'27</th>
                        <th>Sáb'27</th>
                        <th>Dom'27</th>
                        <th>Aloj.</th>
                        <th>Menú</th>
                        <th>Confirmado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% groups.forEach(group => { %>
                        <% group.members.forEach(guest => { %>
                        <tr data-search="<%= (guest.fullname + ' ' + group.group_name).toLowerCase() %>">
                            <td>
                                <div class="td-name"><%= guest.fullname %></div>
                                <% if (group.is_vip) { %><span class="badge badge-vip">VIP</span><% } %>
                            </td>
                            <td class="td-group"><%= group.group_name %></td>
                            <td>
                                <% const ag = guest.age_group || 'adulto'; %>
                                <span class="badge <%= ag === 'adulto' ? 'badge-adulto' : ag === 'adolescente' ? 'badge-adol' : 'badge-nino' %>">
                                    <%= ag === 'adulto' ? '👤 Adulto' : ag === 'adolescente' ? '🧑 Adol.' : '👶 Niño' %>
                                </span>
                            </td>
                            <td style="font-size:0.75rem; color:rgba(255,255,255,0.4)"><%= guest.email || '—' %></td>
                            <td><span class="badge <%= guest.attending_ceremony_2026 ? 'badge-si' : 'badge-no' %>"><%= guest.attending_ceremony_2026 ? 'Sí' : 'No' %></span></td>
                            <td><span class="badge <%= guest.attending_friday_2027 ? 'badge-si' : 'badge-no' %>"><%= guest.attending_friday_2027 ? 'Sí' : 'No' %></span></td>
                            <td><span class="badge <%= guest.attending_saturday_2027 ? 'badge-si' : 'badge-no' %>"><%= guest.attending_saturday_2027 ? 'Sí' : 'No' %></span></td>
                            <td><span class="badge <%= guest.attending_sunday_2027 ? 'badge-si' : 'badge-no' %>"><%= guest.attending_sunday_2027 ? 'Sí' : 'No' %></span></td>
                            <td>
                                <% if (guest.accommodation_status === 'confirmed_free') { %>
                                    <span class="badge badge-conf">✓ Conf.</span>
                                <% } else if (guest.accommodation_status === 'waiting_list') { %>
                                    <span class="badge badge-wait">⏳ Espera</span>
                                <% } else { %>
                                    <span class="badge badge-none">—</span>
                                <% } %>
                            </td>
                            <td><span class="badge badge-menu"><%= guest.menu_type || 'estándar' %></span></td>
                            <td style="font-size:0.72rem; color:rgba(255,255,255,0.35)">
                                <%= guest.confirmed_at ? new Date(guest.confirmed_at).toLocaleDateString('es-ES') : '—' %>
                            </td>
                            <td>
                                <div style="display:flex; gap:6px">
                                    <button class="btn btn-edit"
                                        onclick="openEdit(<%= JSON.stringify({
                                            id: guest.id,
                                            fullname: guest.fullname,
                                            age_group: guest.age_group || 'adulto',
                                            email: guest.email || '',
                                            menu_type: guest.menu_type || 'estandar',
                                            allergies: guest.allergies_specifications || '',
                                            observations: guest.observations || ''
                                        }) %>)">✏ Editar</button>
                                    <form action="/admin/guest/delete/<%= guest.id %>" method="POST" onsubmit="return confirm('¿Eliminar a <%= guest.fullname %>?')">
                                        <button type="submit" class="btn btn-red">✕</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="section-divider"></div>

    <!-- ══ ALERGIAS ══ -->
    <div id="allergy">
        <div class="section-head">
            <span class="section-title">✦ Alergias, menús especiales y observaciones</span>
        </div>
        <% if (allergies.length === 0) { %>
            <p style="color:rgba(255,255,255,0.3); font-size:0.85rem">No hay alergias ni menús especiales registrados.</p>
        <% } else { %>
        <div class="allergy-grid">
            <% allergies.forEach(a => { %>
            <div class="allergy-card">
                <div class="allergy-name"><%= a.fullname %></div>
                <div class="allergy-group"><%= a.group_name %></div>
                <div class="allergy-detail">
                    <% if (a.menu_type && a.menu_type !== 'estandar') { %>
                        <span class="allergy-tag badge badge-menu">🍽 <%= a.menu_type %></span><br>
                    <% } %>
                    <% if (a.allergies_specifications) { %>
                        <span style="color: var(--orange)">⚠ Alergias:</span> <%= a.allergies_specifications %><br>
                    <% } %>
                    <% if (a.observations) { %>
                        <span style="color: rgba(255,255,255,0.4)">📝</span> <%= a.observations %>
                    <% } %>
                </div>
            </div>
            <% }); %>
        </div>
        <% } %>
    </div>

    <div class="section-divider"></div>

    <!-- ══ LISTA DE ESPERA ══ -->
    <div id="waiting">
        <div class="section-head">
            <span class="section-title">✦ Lista de espera · Alojamiento</span>
            <span style="font-family:'Orbitron',monospace; font-size:0.6rem; color:var(--orange)">
                <%= waitingList.length %> persona<%= waitingList.length !== 1 ? 's' : '' %> esperando
            </span>
        </div>
        <% if (waitingList.length === 0) { %>
            <p style="color:rgba(255,255,255,0.3); font-size:0.85rem">✓ Nadie en lista de espera.</p>
        <% } else { %>
        <div class="table-wrap">
            <table class="waiting-table">
                <thead>
                    <tr>
                        <th>Nombre</th><th>Grupo</th><th>Email</th><th>N. Viernes</th><th>N. Sábado</th>
                    </tr>
                </thead>
                <tbody>
                    <% waitingList.forEach(w => { %>
                    <tr>
                        <td class="td-name"><%= w.fullname %></td>
                        <td class="td-group"><%= w.group_name %></td>
                        <td style="font-size:0.75rem; color:rgba(255,255,255,0.4)"><%= w.email || '—' %></td>
                        <td><span class="badge <%= w.accommodation_friday ? 'badge-wait' : 'badge-no' %>"><%= w.accommodation_friday ? '⏳' : '—' %></span></td>
                        <td><span class="badge <%= w.accommodation_saturday ? 'badge-wait' : 'badge-no' %>"><%= w.accommodation_saturday ? '⏳' : '—' %></span></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>

    <div class="section-divider"></div>

    <!-- ══ CONFIGURACIÓN ══ -->
    <div id="settings">
        <div class="section-head">
            <span class="section-title">✦ Configuración</span>
        </div>
        <div class="settings-card">
            <div style="font-family:'Orbitron',monospace; font-size:0.6rem; color:rgba(255,255,255,0.4); margin-bottom:8px">Camas disponibles totales</div>
            <div style="font-size:0.85rem; color:rgba(255,255,255,0.4); margin-bottom:12px">Actualmente: <strong style="color:#fff"><%= stats.max_spots %></strong> · Ocupadas: <strong style="color:var(--green)"><%= stats.confirmed_acc || 0 %></strong> · Libres: <strong style="color:<%= stats.free_spots > 0 ? 'var(--green)' : 'var(--red)' %>"><%= stats.free_spots %></strong></div>
            <form action="/admin/settings/spots" method="POST">
                <div class="settings-row">
                    <input type="number" name="max_spots" value="<%= stats.max_spots %>" min="0" max="999">
                    <button type="submit" class="btn btn-green">Guardar</button>
                </div>
            </form>
        </div>
    </div>

</div>

<!-- ── MODAL EDICIÓN ── -->
<div class="modal-overlay" id="editModal">
    <div class="modal">
        <div class="modal-accent"></div>
        <div class="modal-body">
            <div class="modal-title">✏ Editar invitado</div>
            <form id="editForm" method="POST">
                <input type="hidden" name="id" id="edit-id">
                <div class="modal-field">
                    <label>Nombre completo</label>
                    <input type="text" name="fullname" id="edit-fullname" required>
                </div>
                <div class="modal-field">
                    <label>Grupo de edad</label>
                    <select name="age_group" id="edit-age-group">
                        <option value="adulto">👤 Adulto (18+)</option>
                        <option value="adolescente">🧑 Adolescente (12–17)</option>
                        <option value="nino">👶 Niño (0–11)</option>
                    </select>
                </div>
                <div class="modal-field">
                    <label>Email</label>
                    <input type="email" name="email" id="edit-email">
                </div>
                <div class="modal-field">
                    <label>Tipo de menú</label>
                    <select name="menu_type" id="edit-menu">
                        <option value="estandar">Estándar</option>
                        <option value="vegetariano">Vegetariano</option>
                        <option value="vegano">Vegano</option>
                        <option value="infantil">Infantil</option>
                    </select>
                </div>
                <div class="modal-field">
                    <label>Alergias / Intolerancias</label>
                    <input type="text" name="allergies" id="edit-allergies">
                </div>
                <div class="modal-field">
                    <label>Observaciones</label>
                    <textarea name="observations" id="edit-observations"></textarea>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn btn-cancel" onclick="closeEdit()">Cancelar</button>
                    <button type="submit" class="btn btn-green">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.getElementById('searchInput').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('#guestTable tbody tr').forEach(row => {
        row.style.display = row.dataset.search.includes(q) ? '' : 'none';
    });
});

function openEdit(guest) {
    document.getElementById('edit-id').value = guest.id;
    document.getElementById('edit-fullname').value = guest.fullname;
    document.getElementById('edit-age-group').value = guest.age_group || 'adulto';
    document.getElementById('edit-email').value = guest.email;
    document.getElementById('edit-menu').value = guest.menu_type;
    document.getElementById('edit-allergies').value = guest.allergies;
    document.getElementById('edit-observations').value = guest.observations;
    document.getElementById('editForm').action = '/admin/guest/edit/' + guest.id;
    document.getElementById('editModal').classList.add('open');
}
function closeEdit() { document.getElementById('editModal').classList.remove('open'); }
document.getElementById('editModal').addEventListener('click', function(e) {
    if (e.target === this) closeEdit();
});

const chartDefaults = {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { labels: { color: 'rgba(255,255,255,0.5)', font: { size: 11 }, boxWidth: 12 } } }
};

new Chart(document.getElementById('chartEventos'), {
    type: 'bar',
    data: {
        labels: ['Cer. 2026', 'Vie. 2027', 'Sáb. 2027', 'Dom. 2027'],
        datasets: [{
            data: [<%= stats.ceremony_2026||0 %>, <%= stats.friday_2027||0 %>, <%= stats.saturday_2027||0 %>, <%= stats.sunday_2027||0 %>],
            backgroundColor: ['rgba(255,215,0,0.7)', 'rgba(0,136,255,0.7)', 'rgba(255,0,204,0.7)', 'rgba(0,255,136,0.7)'],
            borderRadius: 3, borderWidth: 0
        }]
    },
    options: { ...chartDefaults, plugins: { legend: { display: false } }, scales: {
        x: { ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
        y: { ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
    }}
});

const menuData = <%- JSON.stringify(menuStats) %>;
new Chart(document.getElementById('chartMenus'), {
    type: 'doughnut',
    data: {
        labels: menuData.map(m => m.menu_type || 'estándar'),
        datasets: [{ data: menuData.map(m => m.total), backgroundColor: ['rgba(0,136,255,0.8)', 'rgba(0,255,136,0.8)', 'rgba(255,215,0,0.8)', 'rgba(255,0,204,0.8)'], borderWidth: 0 }]
    },
    options: { ...chartDefaults, cutout: '65%' }
});

new Chart(document.getElementById('chartEdades'), {
    type: 'doughnut',
    data: {
        labels: ['Adultos', 'Adolescentes', 'Niños'],
        datasets: [{ 
            data: [<%= stats.total_adultos||0 %>, <%= stats.total_adolescentes||0 %>, <%= stats.total_ninos||0 %>],
            backgroundColor: ['rgba(0,255,136,0.8)', 'rgba(255,165,0,0.8)', 'rgba(255,0,204,0.8)'],
            borderWidth: 0
        }]
    },
    options: { ...chartDefaults, cutout: '65%' }
});
</script>
</body>
</html>
